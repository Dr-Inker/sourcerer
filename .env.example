# Sourcerer configuration. Copy to .env and fill in.

# LLM provider key — must match SOURCERER_MODEL's provider (LiteLLM routes by
# model prefix). The default model (openrouter/z-ai/glm-5.1) is routed via
# OpenRouter, so it needs an OpenRouter key:
OPENROUTER_API_KEY=
# ...or set SOURCERER_MODEL to an anthropic/* model and supply this instead:
ANTHROPIC_API_KEY=

# GitHub token (public data only; raises the API rate limit).
GITHUB_TOKEN=

# LiteLLM model id. Leave unset to use the default: openrouter/z-ai/glm-5.1
SOURCERER_MODEL=
