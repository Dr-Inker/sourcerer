# Sourcerer configuration. Copy to .env and fill in.

# LLM provider key — must match SOURCERER_MODEL's provider (LiteLLM routes by
# model prefix). The default model (anthropic/claude-sonnet-4.6) needs an
# Anthropic-compatible key:
ANTHROPIC_API_KEY=
# ...or set SOURCERER_MODEL to an openrouter/* model and supply this instead:
OPENROUTER_API_KEY=

# GitHub token (public data only; raises the API rate limit).
GITHUB_TOKEN=

# LiteLLM model id. Leave unset to use the default: anthropic/claude-sonnet-4.6
SOURCERER_MODEL=
