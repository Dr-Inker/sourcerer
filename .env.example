# Sourcerer configuration. Copy to .env and fill in.
# OpenRouter API key (used by litellm for LLM calls).
OPENROUTER_API_KEY=
# GitHub token (used for the GitHub API; raises rate limits).
GITHUB_TOKEN=
# Model to use, in litellm/OpenRouter form. Defaults to anthropic/claude-sonnet-4.6 if unset.
SOURCERER_MODEL=anthropic/claude-sonnet-4.6
